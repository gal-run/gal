{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gal.run/schemas/model/inference-request.schema.json",
  "title": "GAL Model Inference Request",
  "type": "object",
  "required": [
    "features"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_ref": {
      "const": "https://gal.run/schemas/model/inference-request.schema.json"
    },
    "request_id": {
      "type": "string"
    },
    "application": {
      "type": "string"
    },
    "evidence_ref": {
      "type": "string"
    },
    "model_ref": {
      "const": "gal-model://governance-decision/v0"
    },
    "features": {
      "type": "object",
      "required": [
        "people_present",
        "vehicles_present",
        "obstacles_present",
        "evidence_complete",
        "operator_review_required",
        "latency_measured",
        "approval_refs_complete",
        "detection_count"
      ],
      "additionalProperties": false,
      "properties": {
        "people_present": {
          "type": "boolean"
        },
        "vehicles_present": {
          "type": "boolean"
        },
        "obstacles_present": {
          "type": "boolean"
        },
        "evidence_complete": {
          "type": "boolean"
        },
        "operator_review_required": {
          "type": "boolean"
        },
        "latency_measured": {
          "type": "boolean"
        },
        "approval_refs_complete": {
          "type": "boolean"
        },
        "detection_count": {
          "type": "number",
          "minimum": 0
        }
      }
    }
  }
}
