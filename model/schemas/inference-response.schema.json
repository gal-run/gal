{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gal.run/schemas/model/inference-response.schema.json",
  "title": "GAL Model Inference Response",
  "type": "object",
  "required": [
    "schema_ref",
    "model_ref",
    "architecture",
    "decision",
    "confidence",
    "calibration_bucket",
    "escalate_for_deeper_review",
    "policy_findings",
    "advisory_only",
    "physical_action_allowed",
    "hardware_commands_issued"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_ref": {
      "const": "https://gal.run/schemas/model/inference-response.schema.json"
    },
    "request_id": {
      "type": "string"
    },
    "application": {
      "type": "string"
    },
    "evidence_ref": {
      "type": "string"
    },
    "model_ref": {
      "const": "gal-model://governance-decision/v0"
    },
    "architecture": {
      "enum": [
        "mlp",
        "resnet_mlp"
      ]
    },
    "decision": {
      "enum": [
        "clear_for_operator_review",
        "hold_for_operator_review"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "calibration_bucket": {
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "escalate_for_deeper_review": {
      "type": "boolean"
    },
    "policy_findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "advisory_only": {
      "const": true
    },
    "physical_action_allowed": {
      "const": false
    },
    "hardware_commands_issued": {
      "const": false
    }
  }
}
