{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gal.run/schemas/model/audit-event.schema.json",
  "title": "GAL Normalized Audit Event",
  "type": "object",
  "required": [
    "event_id",
    "application",
    "evidence_ref",
    "split",
    "features",
    "outcome"
  ],
  "additionalProperties": false,
  "properties": {
    "event_id": {
      "type": "string"
    },
    "application": {
      "type": "string"
    },
    "evidence_ref": {
      "type": "string"
    },
    "split": {
      "enum": [
        "train",
        "validation",
        "test"
      ]
    },
    "features": {
      "type": "object",
      "required": [
        "people_present",
        "vehicles_present",
        "obstacles_present",
        "evidence_complete",
        "operator_review_required",
        "latency_measured",
        "approval_refs_complete",
        "detection_count"
      ],
      "additionalProperties": false,
      "properties": {
        "people_present": {
          "type": "boolean"
        },
        "vehicles_present": {
          "type": "boolean"
        },
        "obstacles_present": {
          "type": "boolean"
        },
        "evidence_complete": {
          "type": "boolean"
        },
        "operator_review_required": {
          "type": "boolean"
        },
        "latency_measured": {
          "type": "boolean"
        },
        "approval_refs_complete": {
          "type": "boolean"
        },
        "detection_count": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "outcome": {
      "type": "object",
      "required": [
        "decision"
      ],
      "additionalProperties": false,
      "properties": {
        "decision": {
          "enum": [
            "clear_for_operator_review",
            "hold_for_operator_review"
          ]
        },
        "escalate_for_deeper_review": {
          "type": "boolean"
        }
      }
    }
  }
}
