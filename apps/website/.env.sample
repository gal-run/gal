# Dashboard URL for login/signup links
# Production: https://app.gal.run
# Local development: http://localhost:5173
NEXT_PUBLIC_DASHBOARD_URL=https://app.gal.run

# API URL for direct API calls (optional)
NEXT_PUBLIC_API_URL=https://api.gal.run

# Intercom app ID for chat widget (optional; chat widget is skipped if unset)
# Get from: Intercom Settings > Installation > Web > "app_id" value
NEXT_PUBLIC_INTERCOM_APP_ID=

# Google Analytics measurement ID (optional; analytics skipped if unset)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Ads conversion ID (optional)
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_ID=

# Email-capture provider API key (optional; /api/subscribe returns 503 if unset)
BREVO_API_KEY=

# Email-capture contact list ID (default: 2)
BREVO_EARLY_ACCESS_LIST_ID=2
