{
  "name": "@gal-run/browser-extension",
  "private": false,
  "version": "0.0.674",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "tsc && vite build && vite build --config vite.content.config.ts && npm run copy:manifest",
    "test": "vitest run",
    "test:browser-profiles": "vitest run tests/browser-profile-api.test.ts tests/browser-profile-capture.test.ts tests/browser-profile-export.test.ts tests/host-permissions.test.ts tests/manifest-runtime-regressions.test.ts",
    "watch": "vite build --watch",
    "lint": "eslint .",
    "preview": "vite preview",
    "copy:manifest": "cp public/manifest.json dist/ && mkdir -p dist/icons && cp public/icons/* dist/icons/ && if [ -f dist/src/popup/index.html ]; then mv dist/src/popup/index.html dist/popup.html; fi && rm -rf dist/src",
    "package": "cd dist && zip -r ../gal-extension.zip . -x '*.DS_Store' -x '.claude/*' -x 'logs/*' -x '.vite/*' -x 'README.md' && cd ..",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:e2e:headed": "playwright test --config e2e/playwright.config.ts --headed"
  },
  "dependencies": {
    "@sentry/browser": "^9.0.0",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.556.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/chrome": "^0.1.37",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.5.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "@playwright/test": "^1.50.0"
  }
}
