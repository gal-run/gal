# ─────────────────────────────────────────────────────────────────────────────
# GAL Dashboard — example environment configuration
#
# Copy this file to `.env.local` (for `pnpm dev`) or pass these as build/runtime
# env vars to the Docker image. NEXT_PUBLIC_* values are inlined into the client
# bundle at BUILD time. NONE of these are secrets that must be hidden — a
# Firebase *web* API key is shipped to browsers by design — but this repository
# intentionally ships NO real keys. Provide your own.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL (the GAL API / your own backend).
NEXT_PUBLIC_API_URL=http://localhost:3000

# Deployment environment label: dev | prod
NEXT_PUBLIC_ENVIRONMENT=dev

# ── Firebase web app config (client-side auth). Get these from your Firebase
#    project settings → "Your apps" → Web app. The API key is a public web key.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── GitHub App integration (optional — for repo scanning / install flow).
NEXT_PUBLIC_GITHUB_APP_SLUG=

# Admin org allowlist (comma-separated GitHub org logins), optional.
NEXT_PUBLIC_ADMIN_ORGS=

# Sentry DSN for error reporting (optional).
NEXT_PUBLIC_SENTRY_DSN=

# ── Enterprise (EE) license key ──────────────────────────────────────────────
# Leave BOTH unset for the default single-tenant, fully open-source build.
# Set them to a valid key (format: gal-ee-XXXXXXXXXXXXXXXX...) to enable the
# Enterprise surface under src/ee/** (multi-tenant workspaces, team / org
# membership, billing, managed agents, rate-cards, cross-org repository layer).
#
#   GAL_EE_LICENSE_KEY              -> server-side checks (route handlers, RSC)
#   NEXT_PUBLIC_GAL_EE_LICENSE_KEY -> client-side checks (nav, providers)
#
# This is a PLACEHOLDER only. No real license key is committed to this repo.
GAL_EE_LICENSE_KEY=
NEXT_PUBLIC_GAL_EE_LICENSE_KEY=
