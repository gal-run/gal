{
  "name": "@scheduler-systems/gal-code-console-app",
  "version": "0.1.7",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "dev": "vite dev --host 0.0.0.0",
    "dev:remote": "VITE_AUTH_URL=https://auth.dev.gal.run VITE_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY bun sst shell --stage=dev bun dev",
    "build": "bun ./script/generate-sitemap.ts && vite build && bun ../../gal-code/script/schema.ts ./.output/public/config.json ./.output/public/tui.json",
    "start": "vite start"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "1.15.2",
    "@ibm/plex": "6.4.1",
    "@jsx-email/render": "1.1.1",
    "@kobalte/core": "catalog:",
    "@openauthjs/openauth": "catalog:",
    "@scheduler-systems/gal-code-console-core": "workspace:*",
    "@scheduler-systems/gal-code-console-mail": "workspace:*",
    "@scheduler-systems/gal-code-console-resource": "workspace:*",
    "@scheduler-systems/gal-code-ui": "workspace:*",
    "@smithy/eventstream-codec": "4.2.7",
    "@smithy/util-utf8": "4.2.0",
    "@solidjs/meta": "catalog:",
    "@solidjs/router": "catalog:",
    "@solidjs/start": "catalog:",
    "@stripe/stripe-js": "8.6.1",
    "chart.js": "4.5.1",
    "nitro": "3.0.1-alpha.1",
    "solid-js": "catalog:",
    "solid-list": "0.3.0",
    "solid-stripe": "0.8.1",
    "vite": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@typescript/native-preview": "catalog:",
    "@webgpu/types": "0.1.54",
    "typescript": "catalog:",
    "wrangler": "4.50.0"
  },
  "engines": {
    "node": ">=22"
  }
}
